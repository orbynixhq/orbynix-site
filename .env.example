# Resend API Key — get yours at https://resend.com/api-keys
# Required for the contact form to send emails.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# The "from" email address — must be from a verified domain on Resend.
# If you don't have a verified domain yet, use Resend's shared domain (test only):
#   RESEND_FROM_EMAIL=Orbynix <onboarding@resend.dev>
# With the shared domain, emails can ONLY be sent to your own Resend-verified address.
# To send to any address (gmail etc.), verify your domain at https://resend.com/domains
RESEND_FROM_EMAIL=Orbynix Contact <contact@orbynix.studio>

# The email address that receives contact form submissions
RESEND_TO_EMAIL=buildwithorbynix@gmail.com
